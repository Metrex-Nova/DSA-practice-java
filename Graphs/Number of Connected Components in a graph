This code counts the number of connected components in an undirected graph using BFS (Breadth-First Search). 
It builds an adjacency list from the given edges, then iterates through all vertices; for each unvisited vertex, it starts a new BFS to mark all reachable nodes, increments the component count,
and finally returns the total number of connected components.

Time Complexity: O(V + E) - building the adjacency list takes O(E), BFS traversal visits each vertex and edge once.

Space Complexity: O(V + E) - storing the adjacency list and the visited array of size V, plus the BFS queue which can hold up to V vertices.

import java.util.*;


class Solution{
    public int countComponents(int V, int[][] edges) {
        ArrayList<Integer>[] adj = new ArrayList[V];
        for(int i = 0; i<V; i++){
            adj[i] = new ArrayList<>();
        }
        for(int[] e : edges){
            adj[e[0]].add(e[1]);
            adj[e[1]].add(e[0]);
        }
        boolean[] visited = new boolean[V];
        int components = 0;
        Queue<Integer> q = new LinkedList<>();
        for(int i = 0; i<V; i++){
            if(!visited[i]){
                components++;
                q.offer(i);
                visited[i] = true;
                while(!q.isEmpty()){
                    int node = q.poll();
                    for(int nbr : adj[node]) {
                        if(!visited[nbr]){
                            visited[nbr] = true;
                            q.offer(nbr);
                        }
                    }
                }
            }
        }
        return components;
    }
}


public class Main {
    public static void main(String[] args) {
        // Number of vertices
        int V = 5;

        // List of undirected edges
        int[][] edges = {{0, 1}, {1, 2}, {3, 4}};

        // Create solution object
        Solution sol = new Solution();

        // Print the number of connected components
        System.out.println("Number of Connected Components: " + sol.countComponents(V, edges));
    }
}
